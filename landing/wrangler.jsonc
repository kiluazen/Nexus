{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "nexus-landing",
  "main": "./src/index.js",
  "compatibility_date": "2026-04-28",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "routes": [
    {
      "pattern": "nexus.kushalsm.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
