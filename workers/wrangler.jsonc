{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "nexus-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],

  "kv_namespaces": [
    { "binding": "OAUTH_KV",    "id": "eaaed7dedb9a410281488e12716c5041" },
    { "binding": "NEXUS_CACHE", "id": "7b300dd97fac4570a143cc6a462780bb" }
  ],


  "durable_objects": {
    "bindings": [{ "name": "MCP_OBJECT", "class_name": "NexusMcpAgent" }]
  },

  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["NexusMcpAgent"] }
  ],

  "workers_dev": true,

  "routes": [
    { "pattern": "mcp.nexus.kushalsm.com", "custom_domain": true }
  ],

  "vars": {
    "BASE_URL": "https://mcp.nexus.kushalsm.com",
    "INSTANT_APP_ID": "17362c65-4c31-4e79-be0f-79fdca55c28a",
    "REVIEWER_LOGIN_EMAIL": "openai-reviewer@nexus.kushalsm.com"
  }
}
