{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "nexus-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],

  "kv_namespaces": [
    { "binding": "OAUTH_KV",    "id": "eaaed7dedb9a410281488e12716c5041" },
    { "binding": "NEXUS_CACHE", "id": "7b300dd97fac4570a143cc6a462780bb" }
  ],

  "durable_objects": {
    "bindings": [{ "name": "MCP_OBJECT", "class_name": "NexusMcpAgent" }]
  },

  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["NexusMcpAgent"] }
  ],

  "workers_dev": true,

  "routes": [
    { "pattern": "mcp.nexus.kushalsm.com", "custom_domain": true }
  ],

  "define": {
    "__BASE_URL__": "\"https://mcp.nexus.kushalsm.com\""
  },

  "vars": {
    "BASE_URL": "https://mcp.nexus.kushalsm.com",
    "INSTANT_APP_ID": "17362c65-4c31-4e79-be0f-79fdca55c28a"
  },

  // Staging: same code, separate Worker on a workers.dev URL, so the prod URL
  // under OpenAI review stays frozen while we iterate the widget/tools.
  // Bindings are NOT inherited by named environments, so they're redeclared.
  // KV is shared with prod (fine for a playground); the Durable Object is
  // automatically its own namespace because this is a separate Worker script.
  "env": {
    "staging": {
      "name": "nexus-mcp-staging",
      "compatibility_date": "2026-05-01",
      "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
      "workers_dev": true,
      // Explicitly NO custom-domain routes — staging must never claim the prod
      // hostname (mcp.nexus.kushalsm.com) that OpenAI is reviewing.
      "routes": [],
      "kv_namespaces": [
        { "binding": "OAUTH_KV",    "id": "eaaed7dedb9a410281488e12716c5041" },
        { "binding": "NEXUS_CACHE", "id": "7b300dd97fac4570a143cc6a462780bb" }
      ],
      "durable_objects": {
        "bindings": [{ "name": "MCP_OBJECT", "class_name": "NexusMcpAgent" }]
      },
      "migrations": [
        { "tag": "v1", "new_sqlite_classes": ["NexusMcpAgent"] }
      ],
      "define": {
        "__BASE_URL__": "\"https://nexus-mcp-staging.kushalsokke.workers.dev\""
      },
      "vars": {
        "BASE_URL": "https://nexus-mcp-staging.kushalsokke.workers.dev",
        "INSTANT_APP_ID": "17362c65-4c31-4e79-be0f-79fdca55c28a"
      }
    }
  }
}
